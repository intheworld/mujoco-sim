      <geom name="c5_1" type="box" size="0.01 0.01 0.0002" pos="0.02 -0.03 0.0001" rgba="0 0 0 1" conaffinity="0" contype="0"/>
      <geom name="c7_1" type="box" size="0.01 0.01 0.0002" pos="0.06 -0.03 0.0001" rgba="0 0 0 1" conaffinity="0" contype="0"/>
      
